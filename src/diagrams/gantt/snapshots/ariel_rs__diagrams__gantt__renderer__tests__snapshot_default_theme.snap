<svg id="mermaid-gantt" width="100%" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" viewBox="0 0 1984 148" style="max-width: 1984px;" role="graphics-document document" aria-roledescription="gantt"><style>#mermaid-gantt{font-family:Arial, sans-serif;font-size:16px;fill:#333;}@keyframes edge-animation-frame{from{stroke-dashoffset:0;}}@keyframes dash{to{stroke-dashoffset:0;}}#mermaid-gantt .edge-animation-slow{stroke-dasharray:9,5!important;stroke-dashoffset:900;animation:dash 50s linear infinite;stroke-linecap:round;}#mermaid-gantt .edge-animation-fast{stroke-dasharray:9,5!important;stroke-dashoffset:900;animation:dash 20s linear infinite;stroke-linecap:round;}#mermaid-gantt .error-icon{fill:#552222;}#mermaid-gantt .error-text{fill:#552222;stroke:#552222;}#mermaid-gantt .edge-thickness-normal{stroke-width:1px;}#mermaid-gantt .edge-thickness-thick{stroke-width:3.5px;}#mermaid-gantt .edge-pattern-solid{stroke-dasharray:0;}#mermaid-gantt .edge-thickness-invisible{stroke-width:0;fill:none;}#mermaid-gantt .edge-pattern-dashed{stroke-dasharray:3;}#mermaid-gantt .edge-pattern-dotted{stroke-dasharray:2;}#mermaid-gantt .marker{fill:#333333;stroke:#333333;}#mermaid-gantt .marker.cross{stroke:#333333;}#mermaid-gantt svg{font-family:Arial, sans-serif;font-size:16px;}#mermaid-gantt p{margin:0;}#mermaid-gantt .mermaid-main-font{font-family:Arial, sans-serif;}#mermaid-gantt .exclude-range{fill:#eeeeee;}#mermaid-gantt .section{stroke:none;opacity:0.2;}#mermaid-gantt .section0{fill:rgba(102, 102, 255, 0.49);}#mermaid-gantt .section2{fill:#fff400;}#mermaid-gantt .section1,#mermaid-gantt .section3{fill:white;opacity:0.2;}#mermaid-gantt .sectionTitle0{fill:#333;}#mermaid-gantt .sectionTitle1{fill:#333;}#mermaid-gantt .sectionTitle2{fill:#333;}#mermaid-gantt .sectionTitle3{fill:#333;}#mermaid-gantt .sectionTitle{text-anchor:start;font-family:Arial, sans-serif;}#mermaid-gantt .grid .tick{stroke:lightgrey;opacity:0.8;shape-rendering:crispEdges;}#mermaid-gantt .grid .tick text{font-family:Arial, sans-serif;fill:#333;}#mermaid-gantt .grid path{stroke-width:0;}#mermaid-gantt .today{fill:none;stroke:red;stroke-width:2px;}#mermaid-gantt .task{stroke-width:2;}#mermaid-gantt .taskText{text-anchor:middle;font-family:Arial, sans-serif;}#mermaid-gantt .taskTextOutsideRight{fill:black;text-anchor:start;font-family:Arial, sans-serif;}#mermaid-gantt .taskTextOutsideLeft{fill:black;text-anchor:end;}#mermaid-gantt .task.clickable{cursor:pointer;}#mermaid-gantt .taskText.clickable{cursor:pointer;fill:#003163!important;font-weight:bold;}#mermaid-gantt .taskTextOutsideLeft.clickable{cursor:pointer;fill:#003163!important;font-weight:bold;}#mermaid-gantt .taskTextOutsideRight.clickable{cursor:pointer;fill:#003163!important;font-weight:bold;}#mermaid-gantt .taskText0,#mermaid-gantt .taskText1,#mermaid-gantt .taskText2,#mermaid-gantt .taskText3{fill:white;}#mermaid-gantt .task0,#mermaid-gantt .task1,#mermaid-gantt .task2,#mermaid-gantt .task3{fill:#8a90dd;stroke:#534fbc;}#mermaid-gantt .taskTextOutside0,#mermaid-gantt .taskTextOutside2{fill:black;}#mermaid-gantt .taskTextOutside1,#mermaid-gantt .taskTextOutside3{fill:black;}#mermaid-gantt .active0,#mermaid-gantt .active1,#mermaid-gantt .active2,#mermaid-gantt .active3{fill:#bfc7ff;stroke:#534fbc;}#mermaid-gantt .activeText0,#mermaid-gantt .activeText1,#mermaid-gantt .activeText2,#mermaid-gantt .activeText3{fill:black!important;}#mermaid-gantt .done0,#mermaid-gantt .done1,#mermaid-gantt .done2,#mermaid-gantt .done3{stroke:grey;fill:lightgrey;stroke-width:2;}#mermaid-gantt .doneText0,#mermaid-gantt .doneText1,#mermaid-gantt .doneText2,#mermaid-gantt .doneText3{fill:black!important;}#mermaid-gantt .doneText0.taskTextOutsideLeft,#mermaid-gantt .doneText0.taskTextOutsideRight,#mermaid-gantt .doneText1.taskTextOutsideLeft,#mermaid-gantt .doneText1.taskTextOutsideRight,#mermaid-gantt .doneText2.taskTextOutsideLeft,#mermaid-gantt .doneText2.taskTextOutsideRight,#mermaid-gantt .doneText3.taskTextOutsideLeft,#mermaid-gantt .doneText3.taskTextOutsideRight{fill:black!important;}#mermaid-gantt .crit0,#mermaid-gantt .crit1,#mermaid-gantt .crit2,#mermaid-gantt .crit3{stroke:#ff8888;fill:red;stroke-width:2;}#mermaid-gantt .activeCrit0,#mermaid-gantt .activeCrit1,#mermaid-gantt .activeCrit2,#mermaid-gantt .activeCrit3{stroke:#ff8888;fill:#bfc7ff;stroke-width:2;}#mermaid-gantt .doneCrit0,#mermaid-gantt .doneCrit1,#mermaid-gantt .doneCrit2,#mermaid-gantt .doneCrit3{stroke:#ff8888;fill:lightgrey;stroke-width:2;cursor:pointer;shape-rendering:crispEdges;}#mermaid-gantt .milestone{transform:rotate(45deg) scale(0.8,0.8);}#mermaid-gantt .milestoneText{font-style:italic;}#mermaid-gantt .doneCritText0,#mermaid-gantt .doneCritText1,#mermaid-gantt .doneCritText2,#mermaid-gantt .doneCritText3{fill:black!important;}#mermaid-gantt .doneCritText0.taskTextOutsideLeft,#mermaid-gantt .doneCritText0.taskTextOutsideRight,#mermaid-gantt .doneCritText1.taskTextOutsideLeft,#mermaid-gantt .doneCritText1.taskTextOutsideRight,#mermaid-gantt .doneCritText2.taskTextOutsideLeft,#mermaid-gantt .doneCritText2.taskTextOutsideRight,#mermaid-gantt .doneCritText3.taskTextOutsideLeft,#mermaid-gantt .doneCritText3.taskTextOutsideRight{fill:black!important;}#mermaid-gantt .vert{stroke:navy;}#mermaid-gantt .vertText{font-size:15px;text-anchor:middle;fill:navy!important;}#mermaid-gantt .activeCritText0,#mermaid-gantt .activeCritText1,#mermaid-gantt .activeCritText2,#mermaid-gantt .activeCritText3{fill:black!important;}#mermaid-gantt .titleText{text-anchor:middle;font-size:18px;fill:#333;font-family:Arial, sans-serif;}#mermaid-gantt :root{--mermaid-font-family:Arial, sans-serif;}</style><g></g><g></g><g class="grid" transform="translate(75, 98)" fill="none" font-size="10" font-family="sans-serif" text-anchor="middle"><path class="domain" stroke="currentColor" d="M0.5,-63V0.5H1834.5V-63"></path><g class="tick" opacity="1" transform="translate(220.5,0)"><line stroke="currentColor" y2="-63"></line><text fill="#000