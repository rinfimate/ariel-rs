---
source: src/diagrams/pie/renderer.rs
expression: "crate::svg::normalize_floats(&svg)"
---
<svg id="mermaid-pie" width="100%" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" viewBox="0 0 551.69 450" style="max-width: 551.69px;" role="graphics-document document" aria-roledescription="pie"><style>#mermaid-pie{font-family:Arial, sans-serif;font-size:16px;fill:#333;}@keyframes edge-animation-frame{from{stroke-dashoffset:0;}}@keyframes dash{to{stroke-dashoffset:0;}}#mermaid-pie .edge-animation-slow{stroke-dasharray:9,5!important;stroke-dashoffset:900;animation:dash 50s linear infinite;stroke-linecap:round;}#mermaid-pie .edge-animation-fast{stroke-dasharray:9,5!important;stroke-dashoffset:900;animation:dash 20s linear infinite;stroke-linecap:round;}#mermaid-pie .error-icon{fill:#552222;}#mermaid-pie .error-text{fill:#552222;stroke:#552222;}#mermaid-pie .edge-thickness-normal{stroke-width:1px;}#mermaid-pie .edge-thickness-thick{stroke-width:3.5px;}#mermaid-pie .edge-pattern-solid{stroke-dasharray:0;}#mermaid-pie .edge-thickness-invisible{stroke-width:0;fill:none;}#mermaid-pie .edge-pattern-dashed{stroke-dasharray:3;}#mermaid-pie .edge-pattern-dotted{stroke-dasharray:2;}#mermaid-pie .marker{fill:#333333;stroke:#333333;}#mermaid-pie .marker.cross{stroke:#333333;}#mermaid-pie svg{font-family:Arial, sans-serif;font-size:16px;}#mermaid-pie p{margin:0;}#mermaid-pie .pieCircle{stroke:black;stroke-width:2px;opacity:0.7;}#mermaid-pie .pieOuterCircle{stroke:black;stroke-width:2px;fill:none;}#mermaid-pie .pieTitleText{text-anchor:middle;font-size:25px;fill:black;font-family:Arial, sans-serif;}#mermaid-pie .slice{font-family:Arial, sans-serif;fill:#333;font-size:17px;}#mermaid-pie .legend text{fill:black;font-family:Arial, sans-serif;font-size:17px;}#mermaid-pie :root{--mermaid-font-family:Arial, sans-serif;}</style><g></g><g transform="translate(225,225)"><circle cx="0" cy="0" r="186" class="pieOuterCircle"></circle><path d="M0,-185A185,185,0,1,1,-177.899,-50.763L0,0Z" fill="#ECECFF" class="pieCircle"></path><path d="M-177.899,-50.763A185,185,0,0,1,-35.652,-181.532L0,0Z" fill="#ffffde" class="pieCircle"></path><path d="M-35.652,-181.532A185,185,0,0,1,-0,-185L0,0Z" fill="hsl(80, 100%, 56.275%)" class="pieCircle"></path><text transform="translate(83.573,110.757)" class="slice" style="text-anchor: middle;">79%</text><text transform="translate(-93.903,-102.146)" class="slice" style="text-anchor: middle;">17%</text><text transform="translate(-13.433,-138.098)" class="slice" style="text-anchor: middle;">3%</text><text x="0" y="-200" class="pieTitleText">Pets</text><g class="legend" transform="translate(216,-33)"><rect width="18" height="18" style="fill: #ECECFF; stroke: #ECECFF;"></rect><text x="22" y="14">Dogs</text></g><g class="legend" transform="translate(216,-11)"><rect width="18" height="18" style="fill: #ffffde; stroke: #ffffde;"></rect><text x="22" y="14">Cats</text></g><g class="legend" transform="translate(216,11)"><rect width="18" height="18" style="fill: hsl(80, 100%, 56.275%); stroke: hsl(80, 100%, 56.275%);"></rect><text x="22" y="14">Rats</text></g></g></svg>
