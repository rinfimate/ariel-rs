<text x="197" y="101" text-anchor="middle" dominant-baseline="auto" class="messageText" style="font-family: Arial, sans-serif; font-size: 16px; font-weight: 400;">Hello Bob, how are you?</text><line x1="75" y1="109" x2="315" y2="109" class="messageLine0" data-et="message" data-id="i1" data-from="Alice" data-to="Bob" stroke-width="2" stroke="none" marker-end="url(#mermaid-seq-arrowhead)" style="fill: none;"></line>
