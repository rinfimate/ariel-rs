<text x="197" y="189" text-anchor="middle" dominant-baseline="auto" class="messageText" style="font-family: Arial, sans-serif; font-size: 16px; font-weight: 400;">See you later!</text><line x1="75" y1="197" x2="315" y2="197" class="messageLine0" data-et="message" data-id="i1" data-from="Alice" data-to="Bob" stroke-width="2" stroke="none" marker-end="url(#mermaid-seq-filled-head)" style="fill: none;"></line>
