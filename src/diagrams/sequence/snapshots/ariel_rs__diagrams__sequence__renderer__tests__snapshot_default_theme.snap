<svg id="mermaid-seq" width="100%" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" style="max-width: 494px;" viewBox="-50 -10 494 303" role="graphics-document document" aria-roledescription="sequence">
<style>#mermaid-seq{font-family:Arial, sans-serif;font-size:16px;fill:#333;}
#mermaid-seq p{margin:0;}
#mermaid-seq .actor{stroke:#9370DB;fill:#ECECFF;stroke-width:1;}
#mermaid-seq text.actor>tspan{fill:black;stroke:none;}
#mermaid-seq .actor-line{stroke:#9370DB;}
#mermaid-seq .messageLine0{stroke-width:1.5;stroke-dasharray:none;stroke:#333;}
#mermaid-seq .messageLine1{stroke-width:1.5;stroke-dasharray:2,2;stroke:#333;}
#mermaid-seq [id$="-arrowhead"] path{fill:#333;stroke:#333;}
#mermaid-seq .sequenceNumber{fill:white;}
#mermaid-seq [id$="-sequencenumber"]{fill:#333;}
#mermaid-seq [id$="-crosshead"] path{fill:#333;stroke:#333;}
#mermaid-seq .messageText{fill:#333;stroke:none;}
#mermaid-seq .labelBox{stroke:#9370DB;fill:#ECECFF;filter:none;}
#mermaid-seq .labelText,#mermaid-seq .labelText>tspan{fill:black;stroke:none;}
#mermaid-seq .loopText,#mermaid-seq .loopText>tspan{fill:black;stroke:none;}
#mermaid-seq .sectionTitle,#mermaid-seq .sectionTitle>tspan{fill:black;stroke:none;}
#mermaid-seq .loopLine{stroke-width:2px;stroke-dasharray:2,2;stroke:#9370DB;fill:#9370DB;}
#mermaid-seq .note{stroke:#aaaa33;fill:#fff5ad;}
#mermaid-seq .noteText,#mermaid-seq .noteText>tspan{fill:black;stroke:none;font-weight:normal;}
#mermaid-seq .activation0{fill:#f4f4f4;stroke:#666;}
#mermaid-seq .activation1{fill:#f4f4f4;stroke:#666;}
#mermaid-seq .activation2{fill:#f4f4f4;stroke:#666;}
#mermaid-seq .actor-man circle,#mermaid-seq line{fill:#ECECFF;stroke-width:2px;}</style>
