---
source: src/diagrams/block/renderer.rs
expression: "crate::svg::normalize_floats(&svg)"
---
<svg id="mermaid-block" width="100%" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" style="max-width: 84.658px;" viewBox="-5 -41 84.658 82" role="graphics-document document" aria-roledescription="block"><style>#mermaid-block{font-family:Arial, sans-serif;font-size:16px;fill:#333;}@keyframes edge-animation-frame{from{stroke-dashoffset:0;}}@keyframes dash{to{stroke-dashoffset:0;}}#mermaid-block .edge-animation-slow{stroke-dasharray:9,5!important;stroke-dashoffset:900;animation:dash 50s linear infinite;stroke-linecap:round;}#mermaid-block .edge-animation-fast{stroke-dasharray:9,5!important;stroke-dashoffset:900;animation:dash 20s linear infinite;stroke-linecap:round;}#mermaid-block .error-icon{fill:#552222;}#mermaid-block .error-text{fill:#552222;stroke:#552222;}#mermaid-block .edge-thickness-normal{stroke-width:1px;}#mermaid-block .edge-thickness-thick{stroke-width:3.5px;}#mermaid-block .edge-pattern-solid{stroke-dasharray:0;}#mermaid-block .edge-thickness-invisible{stroke-width:0;fill:none;}#mermaid-block .edge-pattern-dashed{stroke-dasharray:3;}#mermaid-block .edge-pattern-dotted{stroke-dasharray:2;}#mermaid-block .marker{fill:#333333;stroke:#333333;}#mermaid-block .marker.cross{stroke:#333333;}#mermaid-block svg{font-family:Arial, sans-serif;font-size:16px;}#mermaid-block p{margin:0;}#mermaid-block .label{font-family:Arial, sans-serif;color:#333;}#mermaid-block .cluster-label text{fill:#333;}#mermaid-block .cluster-label span,#mermaid-block p{color:#333;}#mermaid-block .label text,#mermaid-block span,#mermaid-block p{fill:#333;color:#333;}#mermaid-block .node rect,#mermaid-block .node circle,#mermaid-block .node ellipse,#mermaid-block .node polygon,#mermaid-block .node path{fill:#ECECFF;stroke:#9370DB;stroke-width:1px;}#mermaid-block .flowchart-label text{text-anchor:middle;}#mermaid-block .node .label{text-align:center;}#mermaid-block .node.clickable{cursor:pointer;}#mermaid-block .arrowheadPath{fill:#333333;}#mermaid-block .edgePath .path{stroke:#333333;stroke-width:2.0px;}#mermaid-block .flowchart-link{stroke:#333333;fill:none;}#mermaid-block .edgeLabel{background-color:rgba(232,232,232, 0.8);text-align:center;}#mermaid-block .edgeLabel p{margin:0;padding:0;display:inline;}#mermaid-block .edgeLabel rect{opacity:0.5;background-color:rgba(232,232,232, 0.8);fill:rgba(232,232,232, 0.8);}#mermaid-block .labelBkg{background-color:rgba(232,232,232, 0.8);}#mermaid-block .node .cluster{fill:rgba(255, 255, 222, 0.5);stroke:rgba(170, 170, 51, 0.2);box-shadow:rgba(50, 50, 93, 0.25) 0px 13px 27px -5px,rgba(0, 0, 0, 0.3) 0px 8px 16px -8px;stroke-width:1px;}#mermaid-block .cluster text{fill:#333;}#mermaid-block .cluster span,#mermaid-block p{color:#333;}#mermaid-block div.mermaidTooltip{position:absolute;text-align:center;max-width:200px;padding:2px;font-family:Arial, sans-serif;font-size:12px;background:hsl(80, 100%, 96.2745098039%);border:1px solid #aaaa33;border-radius:2px;pointer-events:none;z-index:100;}#mermaid-block .flowchartTitleText{text-anchor:middle;font-size:18px;fill:#333;}#mermaid-block .label-icon{display:inline-block;height:1em;overflow:visible;vertical-align:-0.125em;}#mermaid-block .node .label-icon path{fill:currentColor;stroke:revert;stroke-width:revert;}#mermaid-block .node .neo-node{stroke:#9370DB;}#mermaid-block [data-look="neo"].node rect,#mermaid-block [data-look="neo"].cluster rect,#mermaid-block [data-look="neo"].node polygon{stroke:#9370DB;filter:drop-shadow(1px 2px 2px rgba(185, 185, 185, 1));}#mermaid-block [data-look="neo"].node path{stroke:#9370DB;stroke-width:1px;}#mermaid-block [data-look="neo"].node .outer-path{filter:drop-shadow(1px 2px 2px rgba(185, 185, 185, 1));}#mermaid-block [data-look="neo"].node .neo-line path{stroke:#9370DB;filter:none;}#mermaid-block [data-look="neo"].node circle{stroke:#9370DB;filter:drop-shadow(1px 2px 2px rgba(185, 185, 185, 1));}#mermaid-block [data-look="neo"].node circle .state-start{fill:#000000;}#mermaid-block [data-look="neo"].icon-shape .icon{fill:#9370DB;filter:drop-shadow(1px 2px 2px rgba(185, 185, 185, 1));}#mermaid-block [data-look="neo"].icon-shape .icon-neo path{stroke:#9370DB;filter:drop-shadow(1px 2px 2px rgba(185, 185, 185, 1));}#mermaid-block :root{--mermaid-font-family:Arial, sans-serif;}</style><g></g><marker id="mermaid-block_block-pointEnd" class="marker block" viewBox="0 0 10 10" refX="6" refY="5" markerUnits="userSpaceOnUse" markerWidth="12" markerHeight="12" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" class="arrowMarkerPath" style="stroke-width: 1; stroke-dasharray: 1, 0;"></path></marker><marker id="mermaid-block_block-pointStart" class="marker block" viewBox="0 0 10 10" refX="4.5" refY="5" markerUnits="userSpaceOnUse" markerWidth="12" markerHeight="12" orient="auto"><path d="M 0 5 L 10 10 L 10 0 z" class="arrowMarkerPath" style="stroke-width: 1; stroke-dasharray: 1, 0;"></path></marker><marker id="mermaid-block_block-circleEnd" class="marker block" viewBox="0 0 10 10" refX="11" refY="5" markerUnits="userSpaceOnUse" markerWidth="11" markerHeight="11" orient="auto"><circle cx="5" cy="5" r="5" class="arrowMarkerPath" style="stroke-width: 1; stroke-dasharray: 1, 0;"></circle></marker><marker id="mermaid-block_block-circleStart" class="marker block" viewBox="0 0 10 10" refX="-1" refY="5" markerUnits="userSpaceOnUse" markerWidth="11" markerHeight="11" orient="auto"><circle cx="5" cy="5" r="5" class="arrowMarkerPath" style="stroke-width: 1; stroke-dasharray: 1, 0;"></circle></marker><marker id="mermaid-block_block-crossEnd" class="marker cross block" viewBox="0 0 11 11" refX="12" refY="5.2" markerUnits="userSpaceOnUse" markerWidth="11" markerHeight="11" orient="auto"><path d="M 1,1 l 9,9 M 10,1 l -9,9" class="arrowMarkerPath" style="stroke-width: 2; stroke-dasharray: 1, 0;"></path></marker><marker id="mermaid-block_block-crossStart" class="marker cross block" viewBox="0 0 11 11" refX="-1" refY="5.2" markerUnits="userSpaceOnUse" markerWidth="11" markerHeight="11" orient="auto"><path d="M 1,1 l 9,9 M 10,1 l -9,9" class="arrowMarkerPath" style="stroke-width: 2; stroke-dasharray: 1, 0;"></path></marker><g class="block"><g class="node default default flowchart-label" id="mermaid-block-A" transform="translate(9.776, -20)"><rect class="basic label-container" style="" rx="0" ry="0" x="-9.776" y="-16" width="19.553" height="32"></rect><g class="label" style="" transform="translate(-5.335, -12)"><rect></rect><foreignObject width="10.67" height="24"><div xmlns="http://www.w3.org/1999/xhtml" style="display: table-cell; white-space: nowrap; line-height: 1.5;"><span class="nodeLabel "><p>A</p></span></div></foreignObject></g></g><g class="node default default flowchart-label" id="mermaid-block-B" transform="translate(37.329, -20)"><rect class="basic label-container" style="" rx="0" ry="0" x="-9.776" y="-16" width="19.553" height="32"></rect><g class="label" style="" transform="translate(-5.335, -12)"><rect></rect><foreignObject width="10.67" height="24"><div xmlns="http://www.w3.org/1999/xhtml" style="display: table-cell; white-space: nowrap; line-height: 1.5;"><span class="nodeLabel "><p>B</p></span></div></foreignObject></g></g><g class="node default default flowchart-label" id="mermaid-block-C" transform="translate(64.882, -20)"><rect class="basic label-container" style="" rx="0" ry="0" x="-9.776" y="-16" width="19.553" height="32"></rect><g class="label" style="" transform="translate(-5.776, -12)"><rect></rect><foreignObject width="11.553" height="24"><div xmlns="http://www.w3.org/1999/xhtml" style="display: table-cell; white-space: nowrap; line-height: 1.5;"><span class="nodeLabel "><p>C</p></span></div></foreignObject></g></g><g class="node default default flowchart-label" id="mermaid-block-D" transform="translate(37.329, 20)"><rect class="basic label-container" style="" rx="0" ry="0" x="-9.776" y="-16" width="19.553" height="32"></rect><g class="label" style="" transform="translate(-5.776, -12)"><rect></rect><foreignObject width="11.553" height="24"><div xmlns="http://www.w3.org/1999/xhtml" style="display: table-cell; white-space: nowrap; line-height: 1.5;"><span class="nodeLabel "><p>D</p></span></div></foreignObject></g></g></g></svg>
