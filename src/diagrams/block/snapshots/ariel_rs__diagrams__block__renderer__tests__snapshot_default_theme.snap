<svg id="mermaid-block" width="100%" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" style="max-width: 86px;" viewBox="-5 -34 86 68" role="graphics-document document" aria-roledescription="block"><style>#mermaid-block{font-family:Arial,sans-serif;font-size:16px;fill:#333333;}#mermaid-block svg{font-family:Arial,sans-serif;font-size:16px;}#mermaid-block p{margin:0;}#mermaid-block .label{font-family:Arial,sans-serif;color:#333333;}#mermaid-block .cluster-label text{fill:#333333;}#mermaid-block .cluster-label span,#mermaid-block p{color:#333333;}#mermaid-block .label text,#mermaid-block span,#mermaid-block p{fill:#333333;color:#333333;}#mermaid-block .node rect,#mermaid-block .node circle,#mermaid-block .node ellipse,#mermaid-block .node polygon,#mermaid-block .node path{fill:#ECECFF;stroke:#9370DB;stroke-width:1px;}#mermaid-block .flowchart-label text{text-anchor:middle;}#mermaid-block .node .label{text-align:center;}#mermaid-block .arrowheadPath{fill:#333333;}#mermaid-block .edgePath .path{stroke:#333333;stroke-width:2.0px;}#mermaid-block .flowchart-link{stroke:#333333;fill:none;}</style><g></g><marker id="mermaid-block_block-pointEnd" class="marker block" viewBox="0 0 10 10" refX="6" refY="5" markerUnits="userSpaceOnUse" markerWidth="12" markerHeight="12" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" class="arrowMarkerPath" style="fill:#333333;stroke:#333333;stroke-width:1;stroke-dasharray:1,0;"></path></marker><marker id="mermaid-block_block-pointStart" class="marker block" viewBox="0 0 10 10" refX="4.5" refY="5" markerUnits="userSpaceOnUse" markerWidth="12" markerHeight="12" orient="auto"><path d="M 0 5 L 10 10 L 10 0 z" class="arrowMarkerPath" style="fill:#333333;stroke:#333333;stroke-width:1;stroke-dasharray:1,0;"></path></marker><marker id="mermaid-block_block-circleEnd" class="marker block" viewBox="0 0 10 10" refX="11" refY="5" markerUnits="userSpaceOnUse" markerWidth="11" markerHeight="11" orient="auto"><circle cx="5" cy="5" r="